# ============================================================================
# BiblioSpace - variables d'environnement de production
# Copier en .env sur la VM (ne jamais committer .env sur git !)
# Toutes les valeurs entre crochets [...] sont à renseigner.
# ============================================================================

# ---- Images Docker (GHCR) -------------------------------------------------
# Adapter le namespace à ton compte GitHub.
GHCR_NAMESPACE=ghcr.io/iztochenvalk
IMAGE_TAG=latest

# ---- Base de données MySQL ------------------------------------------------
# Mot de passe root MySQL (long et aléatoire, généré avec openssl rand).
MYSQL_ROOT_PASSWORD=[GENERER_AVEC: openssl rand -base64 32]

# Base de données applicative
MYSQL_DATABASE=bibliospace

# Utilisateur applicatif (Spring Boot s'y connecte)
MYSQL_USER=bibliospace
MYSQL_PASSWORD=[GENERER_AVEC: openssl rand -base64 32]

# ---- Spring Boot / JWT ----------------------------------------------------
APP_JWT_ISSUER=bibliospace.florianchague.dev
APP_JWT_EXPIRATION_MINUTES=60

# ---- Override des mots de passe des utilisateurs du seed JSON --------------
# Le fichier bootstrap/users.seed.json embarque 13 utilisateurs de demo
# (1 admin, 2 bibliothecaires, 10 adherents) avec des passwords lisibles
# (Admin123!, Biblio123!, User12345!) — utiles en dev mais a NE PAS exposer
# en prod. En prod, on les remplace par role via les variables ci-dessous.
APP_DEMO_PASSWORD_ADMIN=[GENERER_AVEC: openssl rand -base64 24]
APP_DEMO_PASSWORD_BIBLIOTHECAIRE=[GENERER_AVEC: openssl rand -base64 24]
APP_DEMO_PASSWORD_ADHERENT=[GENERER_AVEC: openssl rand -base64 24]
